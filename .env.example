# ERPNext (UAT) connection for capturing lucky-draw entries.
# Copy to .env.local for local dev; set the same keys in Netlify
# (Site settings → Environment variables) for production.
# Never commit real values.

ERP_URL=https://your-uat-erpnext.example.com
ERP_API_KEY=your_api_key
ERP_API_SECRET=your_api_secret

# The DocType your form_pro form writes to (defaults to "Lucky Draw Entry")
ERP_DOCTYPE=Lucky Draw Entry
